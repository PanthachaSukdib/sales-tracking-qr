# Server configurations
PORT=3000
NODE_ENV=development

# Database configurations (SQLite)
# Specifies the local relative or absolute file path to the SQLite database
DATABASE_PATH=./data/database.db

# Frontend configurations
# Used to construct the survey URL embedded in the generated QR Code
SURVEY_BASE_URL=http://localhost:3000/survey.html

# Dashboard Credentials (Basic Authentication)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme
